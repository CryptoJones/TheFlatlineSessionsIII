; Engine configuration file.
; The Flatline Sessions III — Mona Lisa Underdrive
;
; Modern-look sequel built on the Flatline Sessions engine (neuromancer-godot).
; Open in Godot 4.x.

config_version=5

[application]

config/name="The Flatline Sessions III — Mona Lisa Underdrive"
config/version="1.0.2"
config/description="The Flatline Sessions III — Mona Lisa Underdrive, a fan-made modern adventure after a famous cyberpunk trilogy. Chapter-based, playable from every point of view: Kumiko, Slick Henry, Mona, and Angie Mitchell."
run/main_scene="res://scenes/Boot.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://src/core/GameState.gd"
Assets="*res://src/core/Assets.gd"
AudioManager="*res://src/core/AudioManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1600
window/size/window_height_override=900
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
